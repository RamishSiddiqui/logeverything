{
  "packages": {
    ".": {
      "release-type": "python",
      "extra-files": [
        "logeverything/__init__.py"
      ]
    },
    "logeverything-dashboard": {
      "release-type": "python",
      "package-name": "logeverything-dashboard",
      "extra-files": [
        "logeverything-dashboard/pyproject.toml"
      ]
    }
  },
  "separate-pull-requests": false,
  "include-component-in-tag": false,
  "changelog-sections": [
    {
      "type": "feat",
      "section": "Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "Bug Fixes",
      "hidden": false
    },
    {
      "type": "chore",
      "section": "Chores",
      "hidden": false
    }
  ],
  "skip-github-release": false,
  "draft": false,
  "prerelease": false,
  "pull-request-header": "Automated Release Pull Request",
  "skip-labeling": true
}
